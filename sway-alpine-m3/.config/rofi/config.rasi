configuration {
    modi:                       "drun,run,window";
    show-icons:                 true;
    icon-theme:                 "Papirus";
    drun-display-format:        "{name}";
    display-drun:               "";
    display-run:                "";
    display-window:             "";
    disable-history:            false;
    cycle:                      true;
    sidebar-mode:               false;
    click-to-exit:              true;
}

@theme "theme.rasi"
